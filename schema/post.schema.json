{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://secw01f.github.io/schema/post.schema.json",
  "title": "Post metadata",
  "description": "The application/post+json block a CMS emits inside each src/content/posts/<id>.html file.",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "type", "date", "title", "excerpt", "tags"],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$",
      "description": "URL slug; must match the filename stem."
    },
    "type": {
      "type": "string",
      "enum": ["writeup", "notes", "advisory"]
    },
    "date": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$",
      "description": "Publish date, YYYY-MM-DD."
    },
    "title": { "type": "string", "minLength": 1 },
    "excerpt": { "type": "string", "minLength": 1 },
    "tags": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "minItems": 1
    },
    "diffAdd": { "type": "string" },
    "diffRem": { "type": "string" },
    "severity": {
      "type": "string",
      "enum": ["none", "low", "medium", "high", "critical"]
    },
    "cve": {
      "type": "string",
      "pattern": "^CVE-\\d{4}-\\d{4,}$"
    }
  },
  "allOf": [
    {
      "if": { "properties": { "type": { "const": "writeup" } } },
      "then": { "required": ["diffAdd", "diffRem"] }
    },
    {
      "if": { "properties": { "type": { "const": "advisory" } } },
      "then": { "required": ["severity"] }
    }
  ]
}
